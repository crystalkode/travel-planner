generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trips     Trip[]
}

model Trip {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  userId    String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  endDate   DateTime?
  startDate DateTime?
  status    TripStatus @default(DRAFT)

  days Day[]
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Day {
  id     String @id @default(uuid()) @db.Uuid
  tripId String @db.Uuid
  /// Logical day number (Day 1, Day 2, etc.)
  index      Int
  /// Optional display title (e.g. "Arrival Day")
  title      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  activities Activity[]
  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, index])
}

model Activity {
  id    String @id @default(uuid()) @db.Uuid
  dayId String @db.Uuid

  position Int

  title           String
  description     String?
  type            ActivityType   @default(ACTIVITY)
  schedulingType  SchedulingType @default(FLEXIBLE)

  startTime       DateTime?
  endTime         DateTime?

  locationName    String?
  locationAddress String?
  mapUrl          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  day Day @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
  @@index([dayId, position])
  @@index([dayId, startTime])
}

enum TripStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
}

enum ActivityType {
  ACTIVITY
  TRAVEL
}

enum SchedulingType {
  FIXED
  FLEXIBLE
}
